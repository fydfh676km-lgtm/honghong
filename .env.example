# Database (set one of these on Vercel)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# LLM (Volcengine Ark / Doubao)
ARK_API_KEY=your_ark_api_key

# Voice (Coze TTS/ASR) - optional
COZE_WORKLOAD_IDENTITY_API_KEY=your_coze_pat_key
COZE_INTEGRATION_BASE_URL=https://integration.coze.cn

# Cloudflare Turnstile (optional, for register/login bot protection)
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=your_turnstile_site_key
CLOUDFLARE_TURNSTILE_SECRET_KEY=your_turnstile_secret_key
